---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articles } from "../lib/mockData";

const categories = [
  { id: "", label: "Все" },
  { id: "news", label: "Новости" },
  { id: "events", label: "Анонсы" },
  { id: "career", label: "Карьера" },
  { id: "students", label: "Поступление" },
  { id: "sport", label: "Спорт" },
  { id: "culture", label: "Культура" },
];

const currentCategory = Astro.url.searchParams.get("category") || "";
const displayArticles = currentCategory ? articles.filter((article) => article.category === currentCategory) : articles;
---

<Layout title="Блог — Гуламта">
  <section class="page-hero blog-hero">
    <div class="container">
      <span class="eyebrow">Блог и архив</span>
      <h1 class="page-title">Новости, анонсы и полезные материалы</h1>
      <p class="page-lead">Сайт станет архивом контента Гуламты: карьерные заметки, поступление, спорт, Бурятский четверг и отчёты с мероприятий.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="filters">
        {categories.map((category) => (
          <a href={category.id ? `/articles?category=${category.id}` : "/articles"} class:list={{ active: currentCategory === category.id }}>
            {category.label}
          </a>
        ))}
      </div>

      <div class="grid-3 articles-grid">
        {displayArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-hero {
    padding-bottom: 20px;
  }

  .blog-hero .page-title {
    max-width: 940px;
    margin-bottom: 22px;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
  }

  .filters a {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: white;
    color: var(--muted);
    font-weight: 800;
    padding: 12px 16px;
  }

  .filters a.active,
  .filters a:hover {
    background: var(--accent);
    color: white;
  }

  .articles-grid {
    align-items: stretch;
  }
</style>
