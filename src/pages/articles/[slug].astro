---
import Layout from "../../layouts/Layout.astro";
import { articles } from "../../lib/mockData";

const { slug } = Astro.params;
const article = articles.find((item) => item.slug === slug);

if (!article) {
  return Astro.redirect("/articles");
}

const categoryMap: Record<string, string> = {
  news: "Новости",
  events: "Анонсы",
  career: "Карьера",
  students: "Поступление",
  sport: "Спорт",
  culture: "Культура",
};

const formattedDate = new Date(article.date).toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`${article.title} — Гуламта`}>
  <article>
    <header class="article-hero">
      <div class="container">
        <div class="article-hero-grid">
          <div>
            <div class="article-meta">
              <span class="badge">{categoryMap[article.category]}</span>
              <time datetime={article.date}>{formattedDate}</time>
              <span>{article.views} просмотров</span>
            </div>
            <h1>{article.title}</h1>
            <p>{article.excerpt}</p>
          </div>
          <img src={article.image} alt={article.title} />
        </div>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="article-layout">
          <div class="article-content card" set:html={article.content} />
          <aside class="sidebar">
            <div class="card sidebar-card">
              <h2>Теги</h2>
              <div class="tags">
                {article.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <div class="card sidebar-card">
              <h2>Поделиться</h2>
              <a href={`https://t.me/share/url?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(article.title)}`} target="_blank" rel="noreferrer">Telegram</a>
              <a href={`https://vk.com/share.php?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(article.title)}`} target="_blank" rel="noreferrer">ВКонтакте</a>
            </div>
          </aside>
        </div>
        <a class="back-link" href="/articles">Назад к блогу</a>
      </div>
    </section>
  </article>
</Layout>

<style>
  .article-hero {
    padding: 64px 0 36px;
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 42px;
    align-items: center;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 24px;
    color: var(--muted);
    font-weight: 700;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 24px;
    font-size: clamp(42px, 6vw, 78px);
    line-height: 0.98;
  }

  .article-hero p {
    color: var(--muted);
    font-size: 20px;
    line-height: 1.7;
  }

  .article-hero img {
    height: 520px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 28px;
    align-items: start;
  }

  .article-content {
    padding: 42px;
    font-size: 19px;
    line-height: 1.85;
  }

  .article-content :global(p) {
    margin-bottom: 22px;
  }

  .sidebar {
    position: sticky;
    top: 112px;
    display: grid;
    gap: 18px;
  }

  .sidebar-card {
    padding: 24px;
  }

  .sidebar-card h2 {
    margin-bottom: 16px;
    font-size: 20px;
  }

  .sidebar-card a {
    display: block;
    margin-top: 10px;
    color: var(--accent);
    font-weight: 800;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags span {
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-hover);
    font-size: 13px;
    font-weight: 800;
    padding: 8px 10px;
  }

  .back-link {
    display: inline-block;
    margin-top: 28px;
    color: var(--accent);
    font-weight: 900;
  }

  @media (max-width: 900px) {
    .article-hero-grid,
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-hero img {
      height: 380px;
    }

    .sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .article-content {
      padding: 26px;
      font-size: 17px;
    }
  }
</style>
