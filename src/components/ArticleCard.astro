---
import type { Article } from "../lib/mockData";

const { article } = Astro.props as { article: Article };

const categoryMap: Record<string, string> = {
  news: "Новости",
  events: "Анонсы",
  career: "Карьера",
  students: "Поступление",
  sport: "Спорт",
  culture: "Культура",
};

const formattedDate = new Date(article.date).toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<a href={`/articles/${article.slug}`} class="article-card">
  <div class="article-image">
    <img src={article.image} alt={article.title} loading="lazy" />
  </div>
  <div class="article-content">
    <div class="article-meta">
      <span class="badge">{categoryMap[article.category]}</span>
      <time datetime={article.date}>{formattedDate}</time>
    </div>
    <h3>{article.title}</h3>
    <p>{article.excerpt}</p>
    <span class="read-more">Читать</span>
  </div>
</a>

<style>
  .article-card {
    display: block;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 30px;
    background: white;
    box-shadow: var(--shadow-md);
    transition: 0.3s ease;
  }

  .article-card:hover {
    transform: translateY(-6px);
  }

  .article-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .article-image img {
    height: 100%;
    transition: transform 0.3s ease;
  }

  .article-card:hover img {
    transform: scale(1.04);
  }

  .article-content {
    padding: 24px;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--muted);
    font-size: 13px;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 24px;
    line-height: 1.15;
  }

  p {
    min-height: 78px;
    color: var(--muted);
  }

  .read-more {
    display: inline-block;
    margin-top: 18px;
    color: var(--accent);
    font-weight: 800;
  }
</style>
